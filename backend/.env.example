# ==================== 应用 / 安全 ====================
APP_ENV=dev
APP_PORT=8008
SECRET_KEY=change-me-in-prod-please            # JWT 签名密钥(生产必须换)
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080              # 7天
RATE_LIMIT_PER_MIN=60                          # Redis 限流

# ==================== 对话大模型 (OpenAI 兼容, 填能拿到的最新版本) ====================
LLM_PROVIDER=qwen                              # qwen | deepseek | openai | vllm | ollama
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=sk-xxxxxxxx
LLM_MODEL=qwen3.7-max                          # 改写/摘要/常规问答/意图识别
LLM_REASON_MODEL=qwen3.7-thinking             # 综述/多跳深度推理(带思考)
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096

# ==================== Embedding (多语言, 跨语言核心) ====================
EMBEDDING_PROVIDER=local                        # local | local_path | dashscope | openai
EMBEDDING_MODEL=qwen3-embedding                 # 备选 BAAI/bge-m3
EMBEDDING_BASE_URL=http://embedding:80/v1
EMBEDDING_API_KEY=
EMBEDDING_DIM=1024                              # ⚠️ 必须 == Milvus dense_vec 维度 == 模型输出维度
EMBEDDING_BATCH=10
EMBEDDING_MODEL_PATH=/models/bge-m3             # 进程内加载路径 (当 PROVIDER 为 local_path 时有效)
EMBEDDING_DEVICE=cpu                            # cpu | cuda

# ==================== Rerank (重排, 多语言) ====================
RERANK_PROVIDER=local                           # local | local_path | dashscope
RERANK_MODEL=qwen3-reranker                      # 备选 BAAI/bge-reranker-v2-m3
RERANK_BASE_URL=http://reranker:80/rerank
RERANK_API_KEY=
RERANK_TOP_N=5                                   # 粗召回后精排保留数
RERANK_MODEL_PATH=/models/bge-reranker-v2-m3    # 进程内加载路径 (当 PROVIDER 为 local_path 时有效)
RERANK_DEVICE=cpu                               # cpu | cuda

# ==================== VLM (图片理解, 图描述) ====================
VLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VLM_API_KEY=sk-xxxxxxxx
VLM_MODEL=qwen3-vl

# ==================== Milvus 向量库 ====================
MILVUS_URI=http://milvus:19530
MILVUS_TOKEN=
MILVUS_COLLECTION=scholarmind_chunks
MILVUS_INDEX_TYPE=HNSW                            # HNSW | IVF_FLAT
MILVUS_METRIC=COSINE

# ==================== MySQL 业务库 ====================
MYSQL_HOST=mysql
MYSQL_PORT=3307
MYSQL_USER=root
MYSQL_PASSWORD=change-me
MYSQL_DB=scholarmind
MYSQL_POOL_SIZE=10

# ==================== PostgreSQL 记忆库 (chat-agent 专属) ====================
PG_HOST=postgres
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=change-me
PG_DB=scholarmind_memory

# ==================== Redis (缓存/RQ队列/会话/限流) ====================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ==================== MinIO 对象存储 ====================
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_PDF=papers
MINIO_BUCKET_FIG=figures
MINIO_SECURE=false

# ==================== 文档解析 Provider ====================
DOCUMENT_PARSER_PROVIDER=docling                     # docling | mineru
DOCUMENT_PARSER_FALLBACK_PROVIDER=none               # none | mineru
DOCLING_ARTIFACTS_PATH=/root/.cache/docling          # Docling 模型/缓存目录（docker-compose 挂载到 data/docling-cache）
DOCLING_ENABLE_OCR=false                             # 是否启用 OCR（首版默认关闭，减少依赖与耗时）
DOCLING_ENABLE_TABLE_STRUCTURE=true                  # 表格结构识别开关

# ==================== MinerU 兼容配置（仅 DOCUMENT_PARSER_PROVIDER=mineru 或 fallback=mineru 时使用） ====================
MINERU_BASE_URL=https://mineru.net/api/kie           # MinerU KIE 云端地址，或本地部署地址
MINERU_PIPELINE_ID=                                  # 在 mineru.net 创建 Pipeline 后填入 ID
REFERENCE_PARSER_PROVIDER=grobid                     # grobid | llm；默认用 GROBID 抽取论文元数据和参考文献
GROBID_BASE_URL=http://grobid:8070                   # 参考文献结构化(仅 REFERENCE_PARSER_PROVIDER=grobid 时生效)


# ==================== 检索 / RAG 参数 ====================
RETRIEVAL_TOP_K=20
HYBRID_DENSE_WEIGHT=0.6                           # dense 与 sparse 融合权重
INGEST_MAX_CONCURRENCY=2                           # worker 并发解析数(防打爆 GPU)

# ==================== RAG 功能开关 (可按需开启/关闭) ====================
ENABLE_INTENT_ROUTER=true                         # 意图路由（不满足条件的请求直接短路）
ENABLE_QUERY_REWRITE=true                         # 查询改写（补全代指与消除歧义）
ENABLE_MULTI_QUERY=false                        # 多查询扩展（默认关闭）
ENABLE_HYDE=true                                # HyDE 假设性文档检索
ENABLE_QUERY_TRANSLATION=true                   # 跨语言翻译
ENABLE_RERANK=true                              # Reranker 重排
ENABLE_CORRECTIVE_RAG=false                     # Corrective RAG
ENABLE_SELF_RAG_REFLECT=false                   # Self-RAG 自检反思
