{
   "permissions": {
    "allow": [
      "Bash(pip *)",
      "Bash(python *)",
      "Bash(docker compose *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "ruff format ${CLAUDE_FILE_PATHS} 2>/dev/null; ruff check --fix ${CLAUDE_FILE_PATHS} 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
